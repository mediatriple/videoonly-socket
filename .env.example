# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Port the HTTP/Socket.IO server listens on (dev).
PORT=3030

# Secret used to verify JWT tokens (or plain token for simple auth).
# Generate a strong random value: openssl rand -hex 32
TOKEN_SECRET=bimvid-wihHav-5mybse

# Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS=https://panel.mediatriple.net,https://vopanelpp.mediatriple.net,https://mtvosoct1.mediatriple.net,http://localhost

# Runtime environment: development | production | test
NODE_ENV=development

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Socket.IO timing settings (ms)
SOCKET_PING_INTERVAL=25000
SOCKET_PING_TIMEOUT=60000
SOCKET_UPGRADE_TIMEOUT=30000
